{
  "name": "prompt-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite --host 127.0.0.1\"",
    "build": "vite build",
    "build:pages": "vite build --base=/prompt-tool/ --outDir=dist-pages && node scripts/build-static-api.mjs dist-pages",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "^4.7.0",
    "express": "^5.1.0",
    "vite": "^7.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
